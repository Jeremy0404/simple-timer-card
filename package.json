{
  "name": "simple-timer-card",
  "version": "0.2.0",
  "description": "A simple Home Assistant Lovelace card to view and control a timer entity.",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "deploy": "vite build --mode deploy",
    "dev:deploy": "vite build --watch --mode deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeremy0404/simple-timer-card.git"
  },
  "bugs": {
    "url": "https://github.com/Jeremy0404/simple-timer-card/issues"
  },
  "homepage": "https://github.com/Jeremy0404/simple-timer-card#readme",
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "timer",
    "hacs"
  ],
  "author": "Jeremy0404",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^25.9.1",
    "eslint": "^9.10.0",
    "globals": "^17.6.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "lit": "^3.2.0"
  }
}
